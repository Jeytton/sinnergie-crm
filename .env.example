# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Obtenha estes valores em: https://supabase.com → seu projeto → Settings → API
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="sua_chave_anonima_aqui"

# ── GEMINI AI ─────────────────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="SUA_CHAVE_GEMINI_AQUI"

# ── AUTENTICAÇÃO ──────────────────────────────────────────────────────────────
# Credenciais de acesso ao painel Sinnergie
VITE_APP_USER="admin"
VITE_APP_PASSWORD="sinnergie"

# ── APP ───────────────────────────────────────────────────────────────────────
APP_URL="MY_APP_URL"
